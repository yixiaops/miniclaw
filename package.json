{
  "name": "miniclaw",
  "version": "0.1.0",
  "description": "Lightweight personal AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "start:cli": "node dist/index.js cli",
    "start:api": "node dist/index.js api",
    "start:feishu": "node dist/index.js feishu",
    "start:web": "node dist/index.js web",
    "start:all": "node dist/index.js all"
  },
  "keywords": [
    "ai",
    "assistant",
    "llm",
    "mcp"
